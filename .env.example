# MpeoaERP MongoDB Configuration
# Copy this to .env and fill in your MongoDB Atlas credentials

# MongoDB Atlas Connection URI
# Format: mongodb+srv://username:password@clustername.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://erpadmin:yourPasswordHere@erpcluster.mongodb.net/?retryWrites=true&w=majority

# Database Name
MONGODB_DATABASE=mpeoa_erp

# Optional: Render specific configs
PORT=8080
NODE_ENV=production

# Optional: Application settings
APP_NAME=MpeoaERP
APP_VERSION=1.0.0
